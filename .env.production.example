# =============================================================================
# Paperclip VN — Production Environment Variables
# =============================================================================
# Sao chép file này thành .env.production rồi điền các giá trị bắt buộc.
# Dùng với: docker compose -f docker/docker-compose.production.yml --env-file .env.production up -d

# =============================================================================
# BẮT BUỘC — Không start được nếu thiếu
# =============================================================================

# Khóa bí mật cho session auth. Sinh bằng: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Mật khẩu PostgreSQL
DB_PASSWORD=

# URL công khai của ứng dụng (có giao thức https://)
PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# =============================================================================
# LLM PROVIDERS — Ít nhất 1 cái để agent hoạt động
# =============================================================================

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# KHUYẾN NGHỊ
# =============================================================================

# Tự động tạo invite admin đầu tiên khi khởi động (nếu chưa có admin)
# Xem invite URL trong logs: docker compose logs server | grep "bootstrap"
# Sau khi tạo xong, xóa biến này đi
BOOTSTRAP_ADMIN_EMAIL=

# Khóa JWT cho agent authentication. Sinh bằng: openssl rand -hex 32
PAPERCLIP_AGENT_JWT_SECRET=

# =============================================================================
# TÙY CHỌN — Đã có giá trị mặc định
# =============================================================================

# Port expose ra host (default: 3100, chỉ bind localhost — nginx forward)
# PAPERCLIP_PORT=3100

# Tên database user/name (default: paperclip)
# DB_USER=paperclip
# DB_NAME=paperclip

# UID/GID của user trong container (default: 1000)
# Đổi nếu file trong volume cần thuộc về user khác trên host
# USER_UID=1000
# USER_GID=1000

# Secrets provider: local_encrypted (default) hoặc none
# PAPERCLIP_SECRETS_PROVIDER=local_encrypted

# Storage provider: local_disk (default) hoặc s3
# PAPERCLIP_STORAGE_PROVIDER=local_disk

# --- S3 Storage (chỉ cần nếu PAPERCLIP_STORAGE_PROVIDER=s3) ---
# PAPERCLIP_STORAGE_S3_BUCKET=paperclip
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
# PAPERCLIP_STORAGE_S3_ENDPOINT=
# PAPERCLIP_STORAGE_S3_PREFIX=
# PAPERCLIP_STORAGE_S3_FORCE_PATH_STYLE=false
